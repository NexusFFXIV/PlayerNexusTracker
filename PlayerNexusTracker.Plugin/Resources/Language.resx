    <!-- Cross-producer "any change for this player" notification. Fed by the
         debouncing aggregator so consecutive history + collection-growth
         signals for the same player coalesce into one chat line.
         {0} = player name. -->
    <data name="ui.notifications.general_change.label"><value>Player changed (any)</value></data>
    <data name="ui.notifications.general_change.description"><value>Fires once per coalesced burst whenever any producer detects a change for a tracked player (rename, FC switch, mount unlock, …). Lightweight roll-up — turn this off if you've enabled the granular per-kind notifications below to avoid duplicate lines.</value></data>
    <data name="ui.notifications.general_change.format"><value>{0} has changed</value></data>

    <!-- Per-kind history rows — off by default; opt in for finer control. -->
    <data name="ui.notifications.history.name_change.label"><value>Name change</value></data>
    <data name="ui.notifications.history.name_change.description"><value>Fires when a tracked player has been renamed.</value></data>
    <data name="ui.notifications.history.name_change.format"><value>{0} was renamed: {1}</value></data>

    <data name="ui.notifications.history.world_change.label"><value>World transfer</value></data>
    <data name="ui.notifications.history.world_change.description"><value>Fires when a tracked player has transferred to a different home world.</value></data>
    <data name="ui.notifications.history.world_change.format"><value>{0} transferred worlds: {1}</value></data>

    <data name="ui.notifications.history.customize_change.label"><value>Appearance change</value></data>
    <data name="ui.notifications.history.customize_change.description"><value>Fires when race / gender of a tracked player changes (Fantasia or similar). Hair/face tweaks aren't tracked.</value></data>
    <data name="ui.notifications.history.customize_change.format"><value>{0} changed appearance: {1}</value></data>

