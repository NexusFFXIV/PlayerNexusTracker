    <data name="ui.notifications.history.freecompany_change.format"><value>{0} – Free Company: {1}</value></data>

    <!-- Collection growth — fires only on count increase, never on TTL refresh
         that didn't change anything. {0} = player name, {1} = number added. -->
    <data name="ui.notifications.enrichment.mounts_increased.label"><value>Mounts collection grew</value></data>
    <data name="ui.notifications.enrichment.mounts_increased.description"><value>Fires when a tracked player's mount count has grown since the last refresh. Driven by FFXIVCollect counts so it never fires on a refresh that didn't actually unlock anything.</value></data>
    <data name="ui.notifications.enrichment.mounts_increased.format"><value>{0} unlocked {1} new mount(s)</value></data>

